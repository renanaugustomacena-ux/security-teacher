{
  "name": "progetto",
  "version": "1.0.0",
  "description": "![License](https://img.shields.io/badge/license-MIT-blue.svg)\r ![Docker](https://img.shields.io/badge/docker-industrial--grade-green.svg)\r ![Status](https://img.shields.io/badge/status-execution-orange.svg)",
  "main": "commitlint.config.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "csp:check": "node scripts/compute-csp.mjs --check",
    "csp:patch": "node scripts/compute-csp.mjs --patch",
    "csp:print": "node scripts/compute-csp.mjs --print",
    "doctrine:check": "node scripts/check-doctrine.mjs",
    "audit:translations": "node scripts/audit-identity-translations.mjs",
    "apk:prepare": "node scripts/cap-prepare.mjs",
    "apk:sync": "npm run apk:prepare && cap sync android",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@capacitor/android": "8.3.1",
    "@capacitor/cli": "8.3.1",
    "@capacitor/core": "8.3.1",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@capawesome/capacitor-google-sign-in": "0.1.2"
  }
}
