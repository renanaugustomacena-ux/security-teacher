# Prettier MUST NOT touch vendored third-party assets — their hashes are
# pinned in vendor/integrity.json (Doctrine §6.1, §7.2). A prettier rewrite
# would silently break the integrity gate.
vendor/

# Build artefacts (never committed but local working copies appear here).
_site/

# Dependency directories.
node_modules/

# Lockfiles must remain in their npm-canonical formatting.
package-lock.json

# Doctrine + security artefacts must NOT be auto-formatted. Prettier's
# markdown formatter mangles blockquotes that contain `>=N` — the `>` is
# misparsed as nested-blockquote syntax — and silently corrupts the
# Banner amendments. We keep these hand-formatted (Doctrine §19.1
# footnote: rule is "Prettier formats source files"; doctrine + runbook
# files are spec, not source). Re-evaluate if Prettier ships a fix.
DOCTRINE.md
SECURITY.md
